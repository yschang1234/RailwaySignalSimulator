<Window x:Class="TFMUMSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TFMUMSimulator.Converters"
        Title="TFM UM Simulator – Field Device (Slave)"
        Height="780" Width="920"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E2E">

    <Window.Resources>
        <!-- ── Value converters ──────────────────────────────────────── -->
        <conv:ByteHexConverter x:Key="ByteHexConverter"/>

        <!-- ── Colour palette ───────────────────────────────────────── -->
        <SolidColorBrush x:Key="AccentBrush"        Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#FF313244"/>
        <SolidColorBrush x:Key="ForegroundBrush"    Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="MutedBrush"         Color="#FF6C7086"/>
        <SolidColorBrush x:Key="GreenBrush"         Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="RedBrush"           Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="YellowBrush"        Color="#FFF9E2AF"/>
        <SolidColorBrush x:Key="OrangeBrush"        Color="#FFFAB387"/>
        <SolidColorBrush x:Key="ActiveToggleBrush"  Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="InactiveBrush"      Color="#FF45475A"/>
        <SolidColorBrush x:Key="ShutdownBrush"      Color="#FFF38BA8"/>

        <!-- ── Section header ───────────────────────────────────────── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── Field label ──────────────────────────────────────────── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── ComboBox ─────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground"               Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource MutedBrush}"/>
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Base Button ──────────────────────────────────────────── -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ConnectButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#FF89B4FA"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisconnectButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource RedBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FaultButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource YellowBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Input ToggleButton (user-controlled field status) ──────── -->
        <Style x:Key="InputToggle" TargetType="ToggleButton">
            <Setter Property="Width"           Value="64"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Background"      Value="{StaticResource InactiveBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveToggleBrush}"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Serial port settings -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Output + Input panels -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Config Board -->
            <RowDefinition Height="*"/>     <!-- Row 3: Communication log -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 – Serial Port Configuration
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="SERIAL PORT CONFIGURATION" Style="{StaticResource SectionHeader}"/>
                <UniformGrid Rows="1" Columns="6" VerticalAlignment="Center">

                    <!-- COM Port -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Port" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding ComPorts}"
                                  SelectedItem="{Binding SelectedComPort}"
                                  IsEnabled="{Binding IsDisconnected}"
                                  MinWidth="90"/>
                    </StackPanel>

                    <!-- Baud Rate -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Baud Rate" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding BaudRates}"
                                  SelectedItem="{Binding SelectedBaudRate}"
                                  IsEnabled="{Binding IsDisconnected}"
                                  MinWidth="90"/>
                    </StackPanel>

                    <!-- Spacer -->
                    <StackPanel/>
                    <StackPanel/>

                    <!-- Connect -->
                    <Button Content="CONNECT"
                            Style="{StaticResource ConnectButton}"
                            Command="{Binding ConnectCommand}"
                            Margin="0,18,8,0"/>

                    <!-- Disconnect -->
                    <Button Content="DISCONNECT"
                            Style="{StaticResource DisconnectButton}"
                            Command="{Binding DisconnectCommand}"
                            Margin="0,18,0,0"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 – Output Indicators (RX) and Input ToggleButtons (TX)
        ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Output indicators (receive-only, driven by SSI master) ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="OUTPUT INDICATORS  (RX ← SSI Master)"
                               Style="{StaticResource SectionHeader}"/>
                    <UniformGrid Rows="2" Columns="4">
                        <!-- O0 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O0" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output0}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O1 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O1" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output1}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O2 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O2" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output2}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O3 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O3" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output3}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O4 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O4" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output4}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O5 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O5" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output5}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O6 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O6" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output6}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                        <!-- O7 -->
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock Text="O7" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Ellipse Width="36" Height="36" Margin="4,4,4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource InactiveBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Output7}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- ── Input ToggleButtons (user toggles to simulate field status) ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="INPUT TOGGLES  (TX → SSI Master response)"
                               Style="{StaticResource SectionHeader}"/>
                    <UniformGrid Rows="2" Columns="4" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I0" Margin="3"
                                      IsChecked="{Binding Input0, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I1" Margin="3"
                                      IsChecked="{Binding Input1, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I2" Margin="3"
                                      IsChecked="{Binding Input2, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I3" Margin="3"
                                      IsChecked="{Binding Input3, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I4" Margin="3"
                                      IsChecked="{Binding Input4, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I5" Margin="3"
                                      IsChecked="{Binding Input5, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I6" Margin="3"
                                      IsChecked="{Binding Input6, Mode=TwoWay}"/>
                        <ToggleButton Style="{StaticResource InputToggle}"
                                      Content="I7" Margin="3"
                                      IsChecked="{Binding Input7, Mode=TwoWay}"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 – Config Board
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsShutDown}" Value="True">
                            <Setter Property="BorderBrush"     Value="{StaticResource ShutdownBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="CONFIG BOARD"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <!-- Shutdown badge -->
                    <Border DockPanel.Dock="Right"
                            CornerRadius="4" Padding="8,2"
                            Background="{StaticResource ShutdownBrush}"
                            Visibility="{Binding IsShutDown,
                                Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                        <TextBlock Text="⚠ SHUTDOWN" FontWeight="Bold" Foreground="#FF1E1E2E" FontSize="11"/>
                    </Border>
                </DockPanel>

                <UniformGrid Rows="1" Columns="6" VerticalAlignment="Center">

                    <!-- Module Address (0–63) -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Module Address (0–63)" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <TextBox Height="28" Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 BorderBrush="{StaticResource MutedBrush}"
                                 Text="{Binding ModuleAddress, UpdateSourceTrigger=LostFocus}"
                                 MinWidth="80"/>
                    </StackPanel>

                    <!-- Config Normal Value -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Config Normal (hex)" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <TextBox Height="28" Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 BorderBrush="{StaticResource MutedBrush}"
                                 Text="{Binding ConfigNormalValue,
                                        Converter={StaticResource ByteHexConverter},
                                        UpdateSourceTrigger=LostFocus}"
                                 MinWidth="80"/>
                    </StackPanel>

                    <!-- Config Maintenance Value -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Config Maint. (hex)" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <TextBox Height="28" Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 BorderBrush="{StaticResource MutedBrush}"
                                 Text="{Binding ConfigMaintenanceValue,
                                        Converter={StaticResource ByteHexConverter},
                                        UpdateSourceTrigger=LostFocus}"
                                 MinWidth="80"/>
                    </StackPanel>

                    <!-- Config validity indicator -->
                    <StackPanel Margin="0,0,10,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Config Status" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <Border Height="28" CornerRadius="4" Padding="8,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfigValid}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold"
                                       FontSize="11" Foreground="#FF1E1E2E">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="MISMATCH"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConfigValid}" Value="True">
                                                <Setter Property="Text" Value="OK"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Fault simulation button -->
                    <StackPanel Margin="0,0,8,0" VerticalAlignment="Bottom">
                        <TextBlock Margin="0,0,0,3">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
                                    <Setter Property="Text" Value="HW Fault: OFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFaultSimulated}" Value="True">
                                            <Setter Property="Text"       Value="HW Fault: ON"/>
                                            <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="SIMULATE FAULT"
                                Style="{StaticResource FaultButton}"
                                Command="{Binding SimulateFaultCommand}"/>
                    </StackPanel>

                    <!-- Reset Shutdown button -->
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text=" " Margin="0,0,0,3"/>
                        <Button Content="RESET SHUTDOWN"
                                Style="{StaticResource ResetButton}"
                                Command="{Binding ResetShutdownCommand}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Mismatch cycle counter -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Mismatch cycle count: "
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding ConfigMismatchCycleCount}"
                               Foreground="{StaticResource YellowBrush}"
                               FontWeight="Bold" FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" / 3  (shutdown at 3)"
                               Style="{StaticResource FieldLabel}"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 3 – Communication Log
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="COMMUNICATION LOG"
                           Style="{StaticResource SectionHeader}"/>
                <DataGrid ItemsSource="{Binding LogEntries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FF45475A"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#1AFFFFFF"
                          Foreground="{StaticResource ForegroundBrush}"
                          BorderThickness="0"
                          FontFamily="Consolas"
                          FontSize="11"
                          SelectionMode="Single"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#FF45475A"/>
                            <Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
                            <Setter Property="FontWeight"      Value="Bold"/>
                            <Setter Property="Padding"         Value="8,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp"
                                            Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Dir"
                                            Binding="{Binding Direction}"
                                            Width="40">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="TX">
                                            <Setter Property="Foreground" Value="{StaticResource YellowBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="RX">
                                            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Raw Data (Hex)"
                                            Binding="{Binding RawHex}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 4 – Status Bar
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4">
            <DockPanel>
                <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource RedBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="Safety Cycle: 850 ms  |  Shutdown threshold: 3 cycles"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="10"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
